# Docker container name
CONTAINER_NAME="publishpress-permissions"

# Docker image name
TERMINAL_IMAGE_NAME="publishpress/dev-workspace-terminal:publishpress-permissions"

# Path to the cache directory for the dev-workspace
CACHE_PATH="./.cache"

# The slug of the plugin to be tested.
PLUGIN_SLUG="publishpress-permissions"

# The domain of the plugin to be tested.
LANG_DOMAIN="publishpress-permissions"

# The directory of the language files.
LANG_DIR="languages"

# OpenAI API key for AI translation in the plugin.
OPENAI_API_KEY=sk-proj-your-openai-key

# Weblate API token for translation management in the plugin.
WEBLATE_API_TOKEN=wlu_your-weblate-token