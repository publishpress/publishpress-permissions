msgstr ""
"Quando o acesso a ficheiros está bloqueado, não definir a propriedade "
"WP_Query 404 / 403"

#: classes/PublishPress/Permissions/Constants.php:110
msgid "HTTP status code to send when file access is blocked"
msgstr "Código de estado HTTP a enviar quando o acesso a ficheiros está bloqueado"

